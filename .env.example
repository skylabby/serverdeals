# ──────────────────────────────────────────────────────────────────────────────
# ServerDeals — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# eBay API (Sandbox for dev, Production for live)
EBAY_APP_ID=your_app_id
EBAY_DEV_ID=your_dev_id
EBAY_CERT_ID=your_cert_id
EBAY_ENV=sandbox

# eBay Notification Verification
# Token used to verify eBay Marketplace Deletion Notification webhook
EBAY_NOTIFICATION_VERIFICATION_TOKEN=your_verification_token

# Database
# When running inside Docker Compose, use the service name "postgres" as host:
DATABASE_URL=postgresql://serverdeals:serverdeals@postgres:5432/serverdeals

# Email alerts (Stage 4 polish)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your_password

# Telegram alerts (Stage 4 polish)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Scraper behavior
# Set to "true" to run a full scrape cycle on container startup
# Set to "false" when running multiple replicas (cron handles scheduling)
SCRAPE_ON_STARTUP=true
